{
  "query": "SELECT \n  a.id, a.accountName, a.totalPosts, a.viralPosts, a.viralRate, a.avgLikes,\n  COUNT(p.id) as actualPostCount,\n  SUM(CASE WHEN p.isViral = 1 THEN 1 ELSE 0 END) as actualViralCount\nFROM ip_accounts a\nLEFT JOIN ip_posts p ON a.id = p.accountId\nGROUP BY a.id, a.accountName, a.totalPosts, a.viralPosts, a.viralRate, a.avgLikes\nORDER BY a.viralPosts DESC\nLIMIT 20;",
